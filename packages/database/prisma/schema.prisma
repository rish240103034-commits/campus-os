generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SemesterType {
  ODD
  EVEN
}

model Campus {
  id          String            @id @default(cuid())
  name        String
  code        String            @unique
  address     String?
  departments Department[]
  sessions    AcademicSession[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Department {
  id        String    @id @default(cuid())
  name      String
  code      String
  campusId  String
  programs  Program[]
  campus    Campus    @relation(fields: [campusId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  faculties Faculty[]

  @@unique([campusId, code])
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  campusId  String
  campus    Campus   @relation(fields: [campusId], references: [id])

  @@unique([campusId, name])
}

model Program {
  id       String @id @default(cuid())
  name     String
  code     String
  degree   String
  duration Int

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  semesters Semester[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  students  Student[]

  @@unique([departmentId, code])
}

model Semester {
  id String @id @default(cuid())

  number Int
  name   String

  programId String
  program   Program @relation(fields: [programId], references: [id])

  courses Course[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  students  Student[]

  @@unique([programId, number])
}

model Course {
  id String @id @default(cuid())

  code        String
  title       String
  credits     Int
  theoryHours Int
  labHours    Int

  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([semesterId, code])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  users User[]
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean @default(true)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  student Student?
  faculty Faculty?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id String @id @default(cuid())

  rollNumber     String @unique
  registrationNo String @unique

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  programId  String
  semesterId String

  program  Program  @relation(fields: [programId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faculty {
  id String @id @default(cuid())

  employeeId  String @unique
  designation String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
